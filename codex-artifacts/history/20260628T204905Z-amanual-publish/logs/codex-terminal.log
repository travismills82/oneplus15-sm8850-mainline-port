commit 01d9e5b98c756c2906e0615212937ae05f5d7859
Author:     travismills82@gmail.com <travismills82@gmail.com>
AuthorDate: Thu Jun 18 17:25:55 2026 -0500
Commit:     travismills82@gmail.com <travismills82@gmail.com>
CommitDate: Thu Jun 18 17:25:55 2026 -0500

    arm64: dts: qcom: add early OnePlus 15 support

    Add a reduced Canoe device tree containing CPUs, PSCI, timer, GICv3, GCC, TLMM and the SE7 GENI debug UART.

    This is an early bring-up description. DRAM sizing remains bootloader-provided and the external GCC clock inputs are temporary fixed-clock placeholders.

diff --git a/arch/arm64/boot/dts/qcom/canoe-oneplus-15.dts b/arch/arm64/boot/dts/qcom/canoe-oneplus-15.dts
new file mode 100644
index 000000000..f3040e74f
--- /dev/null
+++ b/arch/arm64/boot/dts/qcom/canoe-oneplus-15.dts
@@ -0,0 +1,259 @@
+/dts-v1/;
+
+#include <dt-bindings/clock/qcom,gcc-canoe.h>
+#include <dt-bindings/interrupt-controller/arm-gic.h>
+#include <dt-bindings/interrupt-controller/irq.h>
+
+/ {
+	model = "OnePlus 15 (Canoe early bring-up)";
+	compatible = "oneplus,oneplus-15", "qcom,canoe";
+
+	interrupt-parent = <&intc>;
+
+	#address-cells = <2>;
+	#size-cells = <2>;
+
+	aliases {
+		serial0 = &uart7;
+	};
+
+	chosen {
+		stdout-path = "serial0:115200n8";
+		bootargs = "console=ttyMSM0,115200n8 earlycon=qcom_geni,0x00a9c000 keep_bootcon ignore_loglevel loglevel=8";
+	};
+
+	memory@a0000000 {
+		device_type = "memory";
+		/* We expect the bootloader to fill in the size. */
+		reg = <0x0 0xa0000000 0x0 0x0>;
+	};
+
+	bi_tcxo: bi-tcxo-clk {
+		compatible = "fixed-clock";
+		#clock-cells = <0>;
+		clock-frequency = <19200000>;
+	};
+
+	pcie0_pipe_clk: pcie0-pipe-clk {
+		compatible = "fixed-clock";
+		#clock-cells = <0>;
+		clock-frequency = <125000000>;
+	};
+
+	sleep_clk: sleep-clk {
+		compatible = "fixed-clock";
+		#clock-cells = <0>;
+		clock-frequency = <32768>;
+	};
+
+	ufs_rx0_clk: ufs-rx0-clk {
+		compatible = "fixed-clock";
+		#clock-cells = <0>;
+		clock-frequency = <19200000>;
+	};
+
+	ufs_rx1_clk: ufs-rx1-clk {
+		compatible = "fixed-clock";
+		#clock-cells = <0>;
+		clock-frequency = <19200000>;
+	};
+
+	ufs_tx0_clk: ufs-tx0-clk {
