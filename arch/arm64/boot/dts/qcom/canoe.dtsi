/ {
	#address-cells = <2>;
	#size-cells = <2>;

	firmware {
		scm: scm {
			compatible = "qcom,scm-canoe", "qcom,scm";
		};
	};

	psci {
		compatible = "arm,psci-1.0";
		method = "smc";
	};

	chosen {
	};
};
